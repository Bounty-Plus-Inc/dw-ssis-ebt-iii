              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{D91AC86F-074D-42D0-AC6C-18388D404413}"
                  SQLTask:SqlStatementSource="SELECT TOP 1&#xA;&#x9;(SELECT COUNT(Row_Id) FROM dbo.RequestLog&#x9;WHERE TableReference_id = 100087&#xA;&#x9;AND Request_Status = 'SUCCESS') as Request_Count,&#xA;&#x9;Row_Id,&#xA;&#x9;Request_Id, &#xA;&#x9;Record_Count,&#xA;&#x9;Request_Date,&#xA;&#x9;Last_Retrieved_Date&#xA;FROM dbo.RequestLog&#xA;WHERE TableReference_id = 100087&#xA;&#x9;AND Request_Status = 'SUCCESS'&#xA;ORDER BY Row_Id DESC ;"
