U_BRANDCATEGORY,
U_COMPANY,
U_EXCLUDED_FROM_SYNC,
'"+ (DT_WSTR,15) @[User::Request_Id]+"' as  'Request_Id', 
CURRENT_DATE() as 'Request_Date'
FROM "+@[User::SourceTable]+"
WHERE
" +
(
    	@[User::Source_Index] ? 
    	"
	
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' AND
 	"
	:
	" " 
) 
+"
MONTH("+@[User::SourceDate_Reference]+") = "+(DT_WSTR, 2) @ResultSet_Month +"
AND YEAR("+@[User::SourceDate_Reference]+") = "+(DT_WSTR,4) @ResultSet_Year+"
AND DAY("+@[User::SourceDate_Reference]+") = "+(DT_WSTR,4) @ResultSet_Day+"
"+@[User::_AdditionalQueryFilter]+" "</DTS:PropertyExpression>
