          <DTS:Executables>
            <DTS:Executable
              DTS:refId="Package\Transformation.EventHandlers[OnError]\DW - Count * Rows - Transformation (OnError)"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{1D6A4643-F622-4E81-B0B2-6FEED5597F35}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="DW - Count * Rows - Transformation (OnError)"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"SELECT COUNT(*),

(SELECT COUNT(*)
FROM ["+@[User::DestinationTable]+"] 
WHERE
" +
(
    	@[User::Source_Index] ? 
    	"
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' AND
 	"
	:
	" " 
) 
+"
Request_Id = @DestinationRequest_Id ) as test,

(SELECT COALESCE(CAST(MAX("+@[User::DestinationDate_Reference]+") AS DATE), CAST('01-01-1753' AS DATE)) AS 'Current_Last_Retrieved_Date' 
FROM ["+@[User::DestinationTable]+"] 
WHERE
" +
(
    	@[User::Source_Index] ? 
    	"
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' AND
 	"
	:
	" " 
) 
+"
Request_Id =  @DestinationRequest_Id ) as test2

FROM ["+@[User::DestinationTable]+"] 
" +
(
    	@[User::Source_Index] ? 
    	"
	WHERE
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' 
 	"
	:
	" " 
) 
+""</DTS:PropertyExpression>
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{52ED2C90-4294-42B8-9465-D3DA3775C0AE}"
                  SQLTask:SqlStatementSource="SELECT COUNT(*),&#xA;&#xA;(SELECT COUNT(*)&#xA;FROM [] &#xA;WHERE&#xA; &#xA;Request_Id = @DestinationRequest_Id ) as test,&#xA;&#xA;(SELECT COALESCE(CAST(MAX() AS DATE), CAST('01-01-1753' AS DATE)) AS 'Current_Last_Retrieved_Date' &#xA;FROM [] &#xA;WHERE&#xA; &#xA;Request_Id =  @DestinationRequest_Id ) as test2&#xA;&#xA;FROM [] &#xA; "
                  SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
                  <SQLTask:ResultBinding
                    SQLTask:ResultName="0"
                    SQLTask:DtsVariableName="User::End_Record_Count" />
                  <SQLTask:ResultBinding
                    SQLTask:ResultName="1"
                    SQLTask:DtsVariableName="User::Insert_Count" />
                  <SQLTask:ResultBinding
                    SQLTask:ResultName="2"
                    SQLTask:DtsVariableName="User::LastRetrieved_Date" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="DestinationTable"
                    SQLTask:DtsVariableName="User::DestinationTable"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="DestinationCompany"
                    SQLTask:DtsVariableName="User::DestinationCompany"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="DestinationBranch"
                    SQLTask:DtsVariableName="User::DestinationBranch"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="DestinationDate_Reference"
                    SQLTask:DtsVariableName="User::DestinationDate_Reference"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="Request_Id"
                    SQLTask:DtsVariableName="User::Request_Id"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="DestinationRequest_Id"
                    SQLTask:DtsVariableName="User::DestinationRequest_Id"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                </SQLTask:SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>
            <DTS:Executable
              DTS:refId="Package\Transformation.EventHandlers[OnError]\Execute SQL Task (Source Count)"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{30C5AD56-0488-475E-A43C-6D682BB0B341}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Execute SQL Task (Source Count)"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"

SELECT 
	COUNT(*) as Source_Count
FROM 
	"+ @[User::SourceTable]+"
"+(@[User::Source_Index] ? 
    "WHERE	
	(COMPANY IS NOT NULL) AND
    (BRANCH IS NOT NULL) AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' 
 	"
	:
	" " 
)+"
"</DTS:PropertyExpression>
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{C91352CB-FB6C-4AF3-9E70-7F2AF6F23B6A}"
                  SQLTask:SqlStatementSource="&#xA;&#xA;SELECT &#xA;&#x9;COUNT(*) as Source_Count&#xA;FROM &#xA;&#x9;&#xA; &#xA;"
                  SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
                  <SQLTask:ResultBinding
                    SQLTask:ResultName="0"
                    SQLTask:DtsVariableName="User::Source_Count" />
                </SQLTask:SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>
            <DTS:Executable
              DTS:refId="Package\Transformation.EventHandlers[OnError]\Get Destination Max(Request_Id) - Transformation (OnError)"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
