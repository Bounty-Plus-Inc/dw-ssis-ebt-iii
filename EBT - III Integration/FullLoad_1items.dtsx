            <DTS:Executable
              DTS:refId="Package\Instance.EventHandlers[OnError]\Execute SQL Task (Source Count)"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:DelayValidation="True"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{C3923BFB-29D1-4B55-B687-DF64FDFD2A17}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Execute SQL Task (Source Count)"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"

SELECT 
	COUNT(*) as Source_Count
FROM 
	"+ @[User::SourceTable]+"
"+(@[User::Source_Index] ? 
    "WHERE	
	(COMPANY IS NOT NULL) AND
    (BRANCH IS NOT NULL) AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' 
 	"
	:
	" " 
)+"
"</DTS:PropertyExpression>
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{C91352CB-FB6C-4AF3-9E70-7F2AF6F23B6A}"
                  SQLTask:SqlStatementSource="&#xA;&#xA;SELECT &#xA;&#x9;COUNT(*) as Source_Count&#xA;FROM &#xA;&#x9;&#xA; &#xA;"
                  SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
                  <SQLTask:ResultBinding
                    SQLTask:ResultName="0"
                    SQLTask:DtsVariableName="User::Source_Count" />
                </SQLTask:SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>
            <DTS:Executable
              DTS:refId="Package\Instance.EventHandlers[OnError]\Insert _ErrorLog - Instance"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{517408BD-ABA7-4FBD-AD1A-35DD536193E3}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Insert _ErrorLog - Instance"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"
INSERT INTO  "+@[User::_DWMCS_ErrorLog]+"
           (
	   [Reference_Id]
	   ,[Request_Id]
           ,[TableReference_Id]
           ,[Request_Date]
           ,[Request_Time]
           ,[Package_Name]
           ,[Task_Name]
           ,[Error_Code]
           ,[Error_Text]
           ,[Machine_Run])
     VALUES
           ( @Request_Row_Id
    	   ,@Request_Id
           ,@_TableReference_Id
           ,GETDATE()
	   ,GETDATE()
	   ,@PackageName
	   ,@TaskName
	   , @ErrorCode
           ,@ErrorDescription
           ,@MachineName)
"</DTS:PropertyExpression>
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{D91AC86F-074D-42D0-AC6C-18388D404413}"
                  SQLTask:SqlStatementSource="&#xA;INSERT INTO  dbo.ErrorLog&#xA;           (&#xA;&#x9;   [Reference_Id]&#xA;&#x9;   ,[Request_Id]&#xA;           ,[TableReference_Id]&#xA;           ,[Request_Date]&#xA;           ,[Request_Time]&#xA;           ,[Package_Name]&#xA;           ,[Task_Name]&#xA;           ,[Error_Code]&#xA;           ,[Error_Text]&#xA;           ,[Machine_Run])&#xA;     VALUES&#xA;           ( @Request_Row_Id&#xA;    &#x9;   ,@Request_Id&#xA;           ,@_TableReference_Id&#xA;           ,GETDATE()&#xA;&#x9;   ,GETDATE()&#xA;&#x9;   ,@PackageName&#xA;&#x9;   ,@TaskName&#xA;&#x9;   , @ErrorCode&#xA;           ,@ErrorDescription&#xA;           ,@MachineName)&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="@Request_Id"
                    SQLTask:DtsVariableName="User::Request_Id"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="@_TableReference_Id"
                    SQLTask:DtsVariableName="User::_TableReference_Id"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="12"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="@PackageName"
                    SQLTask:DtsVariableName="System::PackageName"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="@TaskName"
                    SQLTask:DtsVariableName="System::TaskName"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="16"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="@ErrorCode"
                    SQLTask:DtsVariableName="System::ErrorCode"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="11"
                    SQLTask:ParameterSize="-1" />
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="@ErrorDescription"
                    SQLTask:DtsVariableName="System::ErrorDescription"
