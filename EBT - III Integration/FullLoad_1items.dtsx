      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Transformation\Execute SQL Task (Month and Year)"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Get the Month and Year that will use for the  &quot;Foreach Loop&quot;"
          DTS:DTSID="{1B94407A-37D8-4789-8824-534228602979}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute SQL Task (Month and Year)"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:PropertyExpression
            DTS:Name="SqlStatementSource">"
SELECT DISTINCT 
    YEAR("+@[User::SourceDate_Reference]+") AS ResultSet_Year,
    MONTH(" +@[User::SourceDate_Reference]+") AS ResultSet_Month,
    DAY(" +@[User::SourceDate_Reference]+") AS ResultSet_Day

FROM "+ @[User::SourceTable]+"

" +
(
(@[User::Source_Index] &amp;&amp; (@[User::_MonthInterval_Query] != "")) ? 
	" WHERE 
	 (COMPANY IS NOT NULL) AND
	 (BRANCH IS NOT NULL) AND
	 COMPANY = '"+ @[User::SourceCompany]+"' AND
	 BRANCH = '"+@[User::SourceBranch]+"' AND
	 "+@[User::SourceDate_Reference]+" &gt; "+@[User::_MonthInterval_Query]+"
     AND "+@[User::SourceDate_Reference]+" &lt; CURRENT_DATE() " 
	:
(@[User::Source_Index] &amp;&amp; @[User::_MonthInterval_Query] =="") ?
	" WHERE 
	 (COMPANY IS NOT NULL) AND
	 (BRANCH IS NOT NULL) AND
	 COMPANY = '"+ @[User::SourceCompany]+"' AND
	 BRANCH = '"+@[User::SourceBranch]+"' "
	:
(!@[User::Source_Index] &amp;&amp; (@[User::_MonthInterval_Query] != "") ) ?
	" WHERE 
	"+@[User::SourceDate_Reference]+" &gt; "+@[User::_MonthInterval_Query]+"
    AND "+@[User::SourceDate_Reference]+" &lt; CURRENT_DATE() "
	:
	""
) 
+ "
ORDER BY 
    ResultSet_Year DESC, 
    ResultSet_Month DESC
"</DTS:PropertyExpression>
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{C91352CB-FB6C-4AF3-9E70-7F2AF6F23B6A}"
              SQLTask:SqlStatementSource="&#xA;SELECT DISTINCT &#xA;    YEAR() AS ResultSet_Year,&#xA;    MONTH() AS ResultSet_Month,&#xA;    DAY() AS ResultSet_Day&#xA;&#xA;FROM &#xA;&#xA;&#xA;ORDER BY &#xA;    ResultSet_Year DESC, &#xA;    ResultSet_Month DESC&#xA;"
              SQLTask:ResultType="ResultSetType_Rowset" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="0"
                SQLTask:DtsVariableName="User::ResultSet" />
            </SQLTask:SqlTaskData>
