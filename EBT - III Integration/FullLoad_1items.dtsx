          <DTS:ObjectData>
            <ExpressionTask
              Expression="@[User::Request_Id] = (DT_WSTR, 6) @[User::_TableReference_Id] +&quot;-&quot;+ (SUBSTRING( (DT_WSTR, 50) ((DT_I8) REPLACE( @[User::LastRequest_Id] , &quot;-&quot;, &quot;&quot;) +1)  ,7, 12) )" />
