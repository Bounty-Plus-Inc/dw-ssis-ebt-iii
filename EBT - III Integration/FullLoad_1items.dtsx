            <DTS:Executable
              DTS:refId="Package\Transformation.EventHandlers[OnError]\Insert _ErrorLog - Transformation"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{E3878097-5BD8-4B7A-BCBD-D2CA3250ECE5}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Insert _ErrorLog - Transformation"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"
INSERT INTO "+@[User::_DWMCS_ErrorLog]+"
           ([Reference_Id]
	   ,[Request_Id]
           ,[TableReference_Id]
           ,[Request_Date]
           ,[Request_Time]
           ,[Package_Name]
           ,[Task_Name]
           ,[Error_Code]
           ,[Error_Text]
           ,[Machine_Run])
     VALUES
           (@Request_Row_Id
	   ,@Request_Id
           ,@_TableReference_Id
           ,GETDATE()
	   ,GETDATE()
	   ,@PackageName
	   ,@TaskName
	   , @ErrorCode
           ,@ErrorDescription
           ,@MachineName)
"</DTS:PropertyExpression>
              <DTS:ObjectData>
