  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Create Request Log"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{4735F0D2-9514-4AE7-B370-5F81D8BF0F4C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create Request Log"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:PropertyExpression
        DTS:Name="SqlStatementSource">"INSERT INTO "+@[User::_DWMCS_RequestLog]+" 
    (Request_Id, TableReference_Id, Request_Date, Request_Time, Last_Retrieved_Date, 
     Insert_Record_Count, Prev_Record_Count, Record_Count, Package_Name, Request_Status, 
     Phase_Name, Machine_Run) 
 VALUES 
    ('-', 
    " + (DT_WSTR, 10) @[User::_TableReference_Id] + ", 
    GETDATE(), 
    CAST(GETDATE() AS TIME), 
    GETDATE(), 
    0, 
    0, 
    0, 
    '" + @[System::PackageName] + "', 
    'On-Going', 
    'Log Creation', 
    '" + @[System::MachineName] + "');
SELECT MAX(Row_Id) FROM  "+@[User::_DWMCS_RequestLog]+"  
WHERE Request_Id = '-' 
AND CAST(Request_Date AS DATE) = CAST(GETDATE() AS DATE)
AND Package_Name = '" + @[System::PackageName] + "' 
AND [Machine_Run] = '" + @[System::MachineName] + "'"</DTS:PropertyExpression>
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D91AC86F-074D-42D0-AC6C-18388D404413}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.RequestLog &#xA;    (Request_Id, TableReference_Id, Request_Date, Request_Time, Last_Retrieved_Date, &#xA;     Insert_Record_Count, Prev_Record_Count, Record_Count, Package_Name, Request_Status, &#xA;     Phase_Name, Machine_Run) &#xA; VALUES &#xA;    ('-', &#xA;    100087, &#xA;    GETDATE(), &#xA;    CAST(GETDATE() AS TIME), &#xA;    GETDATE(), &#xA;    0, &#xA;    0, &#xA;    0, &#xA;    'FullLoad_1items', &#xA;    'On-Going', &#xA;    'Log Creation', &#xA;    'BNTYBGC000929');&#xA;SELECT MAX(Row_Id) FROM  dbo.RequestLog  &#xA;WHERE Request_Id = '-' &#xA;AND CAST(Request_Date AS DATE) = CAST(GETDATE() AS DATE)&#xA;AND Package_Name = 'FullLoad_1items' &#xA;AND [Machine_Run] = 'BNTYBGC000929'"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::Request_Row_Id" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Instance"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:Description="Sequence Container"
      DTS:DTSID="{41D8A4C9-3363-4D33-8E30-DAE818C3CDE9}"
      DTS:ExecutableType="STOCK:SEQUENCE"
      DTS:LocaleID="-1"
      DTS:ObjectName="Instance">
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Instance\Count"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:DelayValidation="True"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{75A7B72F-1977-4AF6-9846-82D307333837}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Count"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:PropertyExpression
            DTS:Name="SqlStatementSource">"SELECT TOP 1
	(SELECT COUNT(Row_Id) FROM "+@[User::_DWMCS_RequestLog]+"	WHERE TableReference_id = "+ (DT_WSTR, 10) @[User::_TableReference_Id] +"
	AND Request_Status = '"+@[User::Request_Status]+"') as Request_Count,
	Row_Id,
	Request_Id, 
	Record_Count,
	Request_Date,
	Last_Retrieved_Date
FROM  "+@[User::_DWMCS_RequestLog]+"
WHERE TableReference_id = "+ (DT_WSTR, 10) @[User::_TableReference_Id] +"
