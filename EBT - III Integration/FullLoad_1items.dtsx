            <DTS:Executable
              DTS:refId="Package\Instance.EventHandlers[OnError]\Update _RequestLog - Instance (Failed)"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{0A7AB305-FF16-49B8-9201-F4BD08808CA2}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Update _RequestLog - Instance (Failed)"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"UPDATE  "+@[User::_DWMCS_RequestLog]+" SET
	Insert_Record_Count = @Insert_Record_Count,
        Prev_Record_Count = @Prev_Record_Count,
        Record_Count = @Record_Count,
	Request_Status = 'Failed' ,
	Phase_Name = 'Instantiate'
WHERE 
    Row_Id = @Request_Row_Id
    AND Package_Name = '"+@[System::PackageName] +"'
    AND [Machine_Run] = '"+ @[System::MachineName] +"'
"</DTS:PropertyExpression>
              <DTS:ObjectData>
