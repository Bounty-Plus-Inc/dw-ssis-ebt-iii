        <DTS:Executable
          DTS:refId="Package\Instance\Get Table Reference"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{E873EE84-3947-4613-85BB-6D437A29A929}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Get Table Reference"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:PropertyExpression
            DTS:Name="SqlStatementSource">"
SELECT 
	
	-- b.Table_Id as DestinationTable_Id,
	bb.Table_Text as SourceTable, 
	b.Company as SourceCompany,
	b.Branch as SourceBranch,
	bb.Primary_Key as SourcePrimary_Key,
	bb.Date_Reference as SourceDate_Reference,
	bb.[Index] as Source_Index,
	-- a.TableReference_Id,
	aa.Table_Text as DestinationTable,
	-- a.Table_Id as SourceTable_Id,
	a.Company as DestinationCompany,
	a.Branch as DestinationBranch,
	aa.Primary_Key as DestinationPrimary_Key,
	aa.Date_Reference as DestinationDate_Reference
	-- aa.[Index] as Destination_Index,

FROM [dbo].[TableReference] a 
INNER JOIN [dbo].[TableMaster] aa ON aa.Table_Id = a.Table_Id 
INNER JOIN [dbo].[TableReference] b ON b.TableReference_Id = a.TableReference_Id AND b.Destination = 0
INNER JOIN [dbo].[TableMaster] bb ON bb.Table_Id = b.Table_Id 

WHERE 
	a.TableReference_Id = "+ (DT_WSTR, 10) @[User::_TableReference_Id]+" AND 
	a.Destination = 1;
"</DTS:PropertyExpression>
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{D91AC86F-074D-42D0-AC6C-18388D404413}"
              SQLTask:SqlStatementSource="&#xA;SELECT &#xA;&#x9;&#xA;&#x9;-- b.Table_Id as DestinationTable_Id,&#xA;&#x9;bb.Table_Text as SourceTable, &#xA;&#x9;b.Company as SourceCompany,&#xA;&#x9;b.Branch as SourceBranch,&#xA;&#x9;bb.Primary_Key as SourcePrimary_Key,&#xA;&#x9;bb.Date_Reference as SourceDate_Reference,&#xA;&#x9;bb.[Index] as Source_Index,&#xA;&#x9;-- a.TableReference_Id,&#xA;&#x9;aa.Table_Text as DestinationTable,&#xA;&#x9;-- a.Table_Id as SourceTable_Id,&#xA;&#x9;a.Company as DestinationCompany,&#xA;&#x9;a.Branch as DestinationBranch,&#xA;&#x9;aa.Primary_Key as DestinationPrimary_Key,&#xA;&#x9;aa.Date_Reference as DestinationDate_Reference&#xA;&#x9;-- aa.[Index] as Destination_Index,&#xA;&#xA;FROM [dbo].[TableReference] a &#xA;INNER JOIN [dbo].[TableMaster] aa ON aa.Table_Id = a.Table_Id &#xA;INNER JOIN [dbo].[TableReference] b ON b.TableReference_Id = a.TableReference_Id AND b.Destination = 0&#xA;INNER JOIN [dbo].[TableMaster] bb ON bb.Table_Id = b.Table_Id &#xA;&#xA;WHERE &#xA;&#x9;a.TableReference_Id = 100087 AND &#xA;&#x9;a.Destination = 1;&#xA;"
              SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="0"
                SQLTask:DtsVariableName="User::SourceTable" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="1"
                SQLTask:DtsVariableName="User::SourceCompany" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="2"
                SQLTask:DtsVariableName="User::SourceBranch" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="3"
                SQLTask:DtsVariableName="User::SourcePrimary_Key" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="4"
                SQLTask:DtsVariableName="User::SourceDate_Reference" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="5"
                SQLTask:DtsVariableName="User::Source_Index" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="6"
                SQLTask:DtsVariableName="User::DestinationTable" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="7"
                SQLTask:DtsVariableName="User::DestinationCompany" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="8"
                SQLTask:DtsVariableName="User::DestinationBranch" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="9"
                SQLTask:DtsVariableName="User::DestinationPrimary_Key" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="10"
                SQLTask:DtsVariableName="User::DestinationDate_Reference" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
