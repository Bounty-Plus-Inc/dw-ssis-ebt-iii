	Last_Retrieved_Date = @Current_Last_Retrieved_Date,
	Insert_Record_Count = @Insert_Count,
        Prev_Record_Count = @LastRecord_Count,
        Record_Count = @End_Record_Count,
	Request_Status = 'Failed' ,
	Phase_Name = 'Transformation'
WHERE 
    Row_Id = @Request_Row_Id
    AND Package_Name = '"+@[System::PackageName] +"'
    AND [Machine_Run] = '"+ @[System::MachineName] +"'
"</DTS:PropertyExpression>
