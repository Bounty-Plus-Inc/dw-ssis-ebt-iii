              <DTS:Variables />
              <DTS:PropertyExpression
                DTS:Name="SqlStatementSource">"SELECT COUNT(*),

(SELECT COUNT(*)
FROM ["+@[User::DestinationTable]+"] 
WHERE
" +
(
    	@[User::Source_Index] ? 
    	"
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' AND
 	"
	:
	" " 
) 
+"
Request_Id = @DestinationRequest_Id ) as test,

(SELECT COALESCE(CAST(MAX("+@[User::DestinationDate_Reference]+") AS DATE), CAST('01-01-1753' AS DATE)) AS 'Current_Last_Retrieved_Date' 
FROM ["+@[User::DestinationTable]+"] 
WHERE
" +
(
    	@[User::Source_Index] ? 
    	"
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' AND
 	"
	:
	" " 
) 
+"
Request_Id =  @DestinationRequest_Id ) as test2

FROM ["+@[User::DestinationTable]+"] 
" +
(
    	@[User::Source_Index] ? 
    	"
	WHERE
	COMPANY IS NOT NULL AND
    	BRANCH IS NOT NULL AND
	COMPANY = '"+ @[User::SourceCompany]+"' AND
   	BRANCH = '"+@[User::SourceBranch]+"' 
 	"
	:
	" " 
) 
+""</DTS:PropertyExpression>
